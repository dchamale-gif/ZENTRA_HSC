# ============================================
# VARIABLES DE ENTORNO - STOCK FLOW
# ============================================
# Copiar este archivo a .env y completar con tus valores

# ============================================
# BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stock_flow_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Database Type: postgresql, mysql, sqlite
DB_TYPE=postgresql

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# SERVIDOR
# ============================================
NODE_ENV=development
PORT=3000
HOST=localhost

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5500

# ============================================
# AUTENTICACIÓN
# ============================================
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=10

# ============================================
# EMAIL (para notificaciones)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@stockflow.com

# ============================================
# ALMACENAMIENTO DE ARCHIVOS
# ============================================
# local, s3, azure
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# AWS S3 (si usas S3)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=stock-flow-bucket
AWS_REGION=us-east-1

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# SEGURIDAD
# ============================================
CORS_ORIGIN=http://localhost:5500,http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# MODO DE DEPURACIÓN
# ============================================
DEBUG=false
DEBUG_SQL=false

# ============================================
# BACKUP
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 0 * * *  # Cron format - diariamente a las 00:00
BACKUP_PATH=./backups

# ============================================
# VERSIÓN DE API
# ============================================
API_VERSION=v1

# ============================================
# CONFIGURACIÓN DE EMPRESA POR DEFECTO
# ============================================
DEFAULT_COMPANY_NAME=Stock Flow Demo
DEFAULT_COMPANY_RIF=J-00000000-0
DEFAULT_COMPANY_CURRENCY=USD

# ============================================
# DATOS DE ADMINISTRADOR
# ============================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@stockflow.com
ADMIN_PASSWORD=change_me_on_first_login

# ============================================
# INTEGRACIONES EXTERNAS
# ============================================

# Stripe (para pagos)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Twilio (para SMS)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Drive (para guardar reportes)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# ============================================
# NOTAS
# ============================================
# 1. Mantener este archivo fuera del repositorio (en .gitignore)
# 2. Cambiar todas las contraseñas y claves en producción
# 3. Usar valores seguros y complejos para JWT_SECRET
# 4. Nunca commitear el archivo .env con valores reales
# 5. Para cada entorno (dev, staging, prod) mantener .env separado
